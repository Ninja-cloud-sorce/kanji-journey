# Supabase (public — safe to expose in browser)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>

# Supabase service role — SERVER ONLY, never expose to browser, no VITE_ prefix
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<key>

# Firebase (client-safe, but keep out of version control)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Gemini model config (Edge Function only — set via: supabase secrets set)
GEMINI_MODEL=gemini-1.5-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash-8b

# Local dev API (optional)
VITE_API_BASE_URL=http://localhost:4000
